// Prisma 7: driverAdapters is GA — no longer needs to be in previewFeatures.
generator client {
  provider = "prisma-client-js"
}

// NOTE: Prisma 7 — connection URLs (`url`, `directUrl`) live in prisma.config.ts,
// not here. The runtime client (src/lib/db.ts) connects via the Neon adapter
// using env.DATABASE_URL directly.
datasource db {
  provider = "postgresql"
}

// ---------- Enums (spec §7) ----------

enum Vertical {
  CAFE
  SALON
  JUICE
  BAKERY
  LAUNDRY
  OTHER
}

enum Plan {
  STARTER
  GROWTH
  PRO
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PassStatus {
  ACTIVE
  REDEEMED
  EXPIRED
  DELETED
  ISSUE_FAILED
  REWARD_READY
}

enum PaymentProvider {
  MYFATOORAH
  // Future: STRIPE, HYPERPAY, etc.
}

enum ChargeStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ---------- Models (spec §7) ----------

model Merchant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  brandColor  String   @default("#000000")
  vertical    Vertical
  ownerEmail  String   @unique
  ownerPhone  String
  clerkUserId String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscription  Subscription?
  programs      LoyaltyProgram[]
  staffPins     StaffPin[]
  paymentMethod PaymentMethod?

  @@index([clerkUserId])
}

model Subscription {
  id               String             @id @default(cuid())
  merchantId       String             @unique
  plan             Plan
  status           SubscriptionStatus
  provider         PaymentProvider    @default(MYFATOORAH)
  providerRef      String?            // RENAMED from hyperpayRef — generic provider invoice/subscription id
  currentPeriodEnd DateTime
  trialEndsAt      DateTime?          // null after trial ends
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  charges  Charge[]
}

model PaymentMethod {
  id          String          @id @default(cuid())
  merchantId  String          @unique
  provider    PaymentProvider @default(MYFATOORAH)
  recurringId String          @unique // MyFatoorah RecurringId returned after first successful charge
  last4       String
  brand       String          // "MADA" | "VISA" | "MASTER" | etc
  expMonth    Int
  expYear     Int
  holderName  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model Charge {
  id                String          @id @default(cuid())
  subscriptionId    String
  amountSar         Int             // Stored in halalas (1 SAR = 100 halalas) for integer precision
  status            ChargeStatus
  provider          PaymentProvider @default(MYFATOORAH)
  providerInvoiceId String?         @unique
  providerPaymentId String?
  failureReason     String?
  attemptedAt       DateTime        @default(now())
  succeededAt       DateTime?

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
}

model StaffPin {
  id         String   @id @default(cuid())
  merchantId String
  pinHash    String
  label      String
  createdAt  DateTime @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
}

model LoyaltyProgram {
  id               String  @id @default(cuid())
  merchantId       String
  name             String
  stampsRequired   Int     @default(10)
  rewardLabel      String
  passKitProgramId String? @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  passes   Pass[]

  @@index([merchantId])
}

model Pass {
  id              String     @id @default(cuid())
  programId       String
  customerPhone   String
  passKitPassId   String     @unique
  applePassUrl    String?
  googleWalletUrl String?
  stampsCount     Int        @default(0)
  status          PassStatus @default(ACTIVE)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  program     LoyaltyProgram     @relation(fields: [programId], references: [id], onDelete: Cascade)
  events      StampEvent[]
  redemptions RewardRedemption[]

  @@index([programId, customerPhone])
  @@index([status])
}

model StampEvent {
  id         String   @id @default(cuid())
  passId     String
  staffPinId String
  source     String   @default("scanner")
  createdAt  DateTime @default(now())

  pass Pass @relation(fields: [passId], references: [id], onDelete: Cascade)

  @@index([passId])
  @@index([createdAt])
}

model RewardRedemption {
  id         String   @id @default(cuid())
  passId     String
  staffPinId String
  redeemedAt DateTime @default(now())

  pass Pass @relation(fields: [passId], references: [id], onDelete: Cascade)

  @@index([passId])
  @@index([redeemedAt])
}
