# ---------- Core ----------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Database (Neon Postgres) ----------
# Pooled connection (used by app at runtime)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/stampme?sslmode=require"
# Direct connection (used by Prisma migrate)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/stampme?sslmode=require"

# ---------- Clerk ----------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ---------- Sentry ----------
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=stampme

# ---------- PostHog ----------
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ---------- Resend (transactional email) ----------
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL="stampme <noreply@stampme.com>"

# ---------- Cloudflare R2 (S3-compatible) ----------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=stampme-assets
R2_PUBLIC_URL=https://assets.stampme.com

# ---------- MyFatoorah (billing) ----------
# Production (KSA): https://api.myfatoorah.com
# Test: https://apitest.myfatoorah.com
MYFATOORAH_API_KEY=
MYFATOORAH_BASE_URL="https://apitest.myfatoorah.com"
MYFATOORAH_WEBHOOK_SECRET=

# Safety flag — set to true only when ready to process real payments
BILLING_AUTO_CHARGE_ENABLED=false

# ---------- Cron / staff / rate limiting (later plans) ----------
CRON_SECRET=
STAFF_JWT_SECRET=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- Unifonic (SMS — wired only, no use in MVP) ----------
UNIFONIC_APP_SID=
UNIFONIC_SENDER_NAME=

# ── PassKit (gRPC mTLS credentials) ──────────────────────────────────────
# Obtain from: PassKit dashboard → Developer Tools → SDK Credentials → Download ZIP
# The ZIP contains certificate.pem, key.pem (encrypted), and ca-chain.pem.
# Decrypt the key: openssl ec -in key.pem -passin pass:<passphrase> -out key_dec.pem
# gRPC host is hardcoded to grpc.pub1.passkit.io:443 in src/lib/passkit/client.ts
#
# Paste the full PEM file contents below (multi-line values inside double-quotes work
# in .env.local; for CI/CD use base64-encoded values and decode in your bootstrap script).
PASSKIT_CERTIFICATE="-----BEGIN CERTIFICATE-----
<paste full certificate.pem content here>
-----END CERTIFICATE-----"
PASSKIT_KEY="-----BEGIN EC PRIVATE KEY-----
<paste full decrypted key.pem content here>
-----END EC PRIVATE KEY-----"
PASSKIT_CA_CHAIN="-----BEGIN CERTIFICATE-----
<paste full ca-chain.pem content here, may contain multiple cert blocks>
-----END CERTIFICATE-----"
# From PassKit dashboard → Webhooks → endpoint signing secret
PASSKIT_WEBHOOK_SECRET="whsec_xxx"
PASSKIT_DEFAULT_TEMPLATE_ID=""
# Margin alert
MARGIN_ALERT_EMAIL="abdullah@stampme.com"
MARGIN_PASS_COST_USD="0.10"
CRON_SECRET="generate-with-openssl-rand-base64-48"
