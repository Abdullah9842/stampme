# ---------- Core ----------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Database (Neon Postgres) ----------
# Pooled connection (used by app at runtime)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/stampme?sslmode=require"
# Direct connection (used by Prisma migrate)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/stampme?sslmode=require"

# ---------- Clerk ----------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ---------- Sentry ----------
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=stampme

# ---------- PostHog ----------
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ---------- Resend (transactional email) ----------
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL="stampme <noreply@stampme.com>"

# ---------- Cloudflare R2 (S3-compatible) ----------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=stampme-assets
R2_PUBLIC_URL=https://assets.stampme.com

# ---------- HyperPay (Plan 6) ----------
HYPERPAY_ENV="test"
HYPERPAY_BASE_URL="https://eu-test.oppwa.com"
HYPERPAY_ACCESS_TOKEN=
HYPERPAY_ENTITY_ID_MADA=
HYPERPAY_ENTITY_ID_CARD=
HYPERPAY_WEBHOOK_KEY_HEX=

# ---------- Cron / staff / rate limiting (later plans) ----------
CRON_SECRET=
STAFF_JWT_SECRET=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- Unifonic (SMS — wired only, no use in MVP) ----------
UNIFONIC_APP_SID=
UNIFONIC_SENDER_NAME=

# ── PassKit ────────────────────────────────────────────────
PASSKIT_API_URL="https://api.pub1.passkit.io"
PASSKIT_API_KEY="pk_live_xxx"
PASSKIT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
PASSKIT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
PASSKIT_WEBHOOK_SECRET="whsec_xxx"
PASSKIT_DEFAULT_TEMPLATE_ID="tpl_xxx"
# Margin alert
MARGIN_ALERT_EMAIL="abdullah@stampme.com"
MARGIN_PASS_COST_USD="0.10"
CRON_SECRET="generate-with-openssl-rand-base64-48"
